OPENAI_API_KEY=sk-...            # DeepSeek key works here too (same sk-... format)
OPENAI_BASE_URL=https://api.deepseek.com   # drop this line to use OpenAI default
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=tax_docs
EMBED_MODEL=BAAI/bge-large-en-v1.5
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
LLM_MODEL=deepseek-chat          # or gpt-4o-mini
MAX_RETRIES=2
TOP_K=5
